  <script>
    // ========================================
    // MEGA MENU
    // ========================================
    const megaMenu = document.getElementById('megaMenu');
    const megaMenuOverlay = document.querySelector('.mega-menu-overlay');
    const tabs = document.querySelectorAll('.mega-menu-tab');

    // Target the FIXED navbar (group-117) elements — the visible ones
    const fixedNavbar = document.querySelector('.group-117');
    const hamburgers = document.querySelectorAll('.group-38');
    const productsButtons = document.querySelectorAll('.navbar-link-text-4');

    function openMegaMenu() {
      megaMenu.classList.add('active');
    }

    function closeMegaMenu() {
      megaMenu.classList.remove('active');
    }

    function toggleMegaMenu(e) {
      e.stopPropagation();
      megaMenu.classList.toggle('active');
    }

    // Attach click to ALL hamburger and products buttons (both navbars)
    hamburgers.forEach(el => el.addEventListener('click', toggleMegaMenu));
    productsButtons.forEach(el => el.addEventListener('click', toggleMegaMenu));

    // Close on overlay click
    megaMenuOverlay.addEventListener('click', closeMegaMenu);

    // Tab switching
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        document.querySelectorAll('.mega-menu-content').forEach(c => c.classList.remove('active'));
        const tabName = tab.getAttribute('data-tab');
        const content = document.getElementById(tabName === 'adults' ? 'adultsContent' : 'kidsContent');
        if (content) content.classList.add('active');
      });
    });

    // ========================================
    // HERO SLIDER
    // The Anima layout uses a 3690px wide flex container (.component-1-1)
    // inside overlap-group1 (4405px, margin-left:-1820px).
    // Slide 2 (group-111) is visible by default (it's at x=1870 inside the container,
    // which maps to viewport x=50 after the -1820px margin offset).
    // To show slide 1, we translateX the container by +1870px.
    // ========================================
    const slider = document.querySelector('.component-1-1');
    const prevBtn = document.getElementById('sliderPrev');
    const nextBtn = document.getElementById('sliderNext');
    let currentSlide = 1; // Start on slide 2 (the one visible by default)
    let slideInterval;
    const SLIDE_OFFSET = 1870; // Distance between slide positions

    function showSlide(index) {
      if (index === 0) {
        // Show slide 1: shift container right
        slider.style.transform = 'translateX(' + SLIDE_OFFSET + 'px)';
      } else {
        // Show slide 2: default position
        slider.style.transform = 'translateX(0)';
      }
      currentSlide = index;
    }

    function nextSlide() {
      currentSlide = (currentSlide + 1) % 2;
      showSlide(currentSlide);
    }

    function prevSlide() {
      currentSlide = (currentSlide - 1 + 2) % 2;
      showSlide(currentSlide);
    }

    function resetAutoSlide() {
      clearInterval(slideInterval);
      slideInterval = setInterval(nextSlide, 5000);
    }

    prevBtn.addEventListener('click', () => { prevSlide(); resetAutoSlide(); });
    nextBtn.addEventListener('click', () => { nextSlide(); resetAutoSlide(); });

    // Auto-advance
    slideInterval = setInterval(nextSlide, 5000);
  </script>

</Layout>
