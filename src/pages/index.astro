---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ProductsAdults from '../components/ProductsAdults.astro';
import ProductsKids from '../components/ProductsKids.astro';
import About from '../components/About.astro';
import Recipes from '../components/Recipes.astro';
import Events from '../components/Events.astro';
import Blog from '../components/Blog.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Nutri Valley - Moments of Delight | Θρεπτικές Επιλογές"
  description="Θρεπτικές επιλογές σχεδιασμένες για τον σύγχρονο τρόπο ζωής. Premium κονσέρβες, μπάρες πρωτεΐνης, γκοφρέτες, ταχίνι και παιδικά προϊόντα."
>
  <Header />

  <main id="main-content">
    <!-- 1. Hero Slider -->
    <Hero />

    <!-- 2. Products for Adults -->
    <ProductsAdults />

    <!-- 3. Kids Products -->
    <ProductsKids />

    <!-- 4. About Section (dark) -->
    <About />

    <!-- 5. Recipes -->
    <Recipes />

    <!-- 6. Events -->
    <Events />

    <!-- 7. Blog -->
    <Blog />
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Page-level: ensure sections flow correctly */
  main {
    display: flex;
    flex-direction: column;
  }

  /* Hero sits just below header (no extra margin — header is sticky) */
  .hero {
    margin-top: 0;
  }
</style>
