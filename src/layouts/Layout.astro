---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nutri Valley - Moments of Delight',
  description = 'Θρεπτικές επιλογές σχεδιασμένες για τον σύγχρονο τρόπο ζωής.',
} = Astro.props;
---
<!doctype html>
<html lang="el">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=1920, maximum-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/assets/images/nutri-valley-logo.svg" />
    <title>{title}</title>
    <!-- Anima CSS (direct from export) -->
    <link rel="stylesheet" href="/css/fonts.css" />
    <link rel="stylesheet" href="/css/globals.css" />
    <link rel="stylesheet" href="/css/styleguide.css" />
    <link rel="stylesheet" href="/css/homepage-desktop.css" />
  </head>
  <body style="margin: 0; background: #ffffff">
    <slot />
  </body>
</html>
