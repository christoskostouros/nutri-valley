---
/* Blog.astro — XD spec: 2 blog post cards (885px × 750px)
   Image (740px height) + overlapping white text bar (180px, top: 570px)
   Cards in flex container: gap 50px, min-width 1820px
*/

const posts = [
  {
    id: 1,
    title: 'ΓΙΑΤΙ ΝΑ ΕΠΙΛΕΞΕΤΕ ΤΟ ΦΙΛΕΤΟ ΚΟΤΟΠΟΥΛΟ ΤΗΣ NUTRI VALLEY',
    excerpt: 'Ανακαλύψτε γιατί το φιλέτο κοτόπουλου Nutri Valley...',
    image: '/assets/images/blog-post-01.webp',
    href: '/blog/fileto-kotopoulo',
  },
  {
    id: 2,
    title: 'ΒΙΩΣΙΜΟΤΗΤΑ ΤΗΣ NUTRI VALLEY',
    excerpt: 'Η Nutri Valley δεσμεύεται για ένα βιώσιμο μέλλον...',
    image: '/assets/images/blog-post-02.webp',
    href: '/blog/biwsimothta',
  },
];
---

<section class="blog">
  <div class="blog__cards-container">
    {posts.map((post) => (
      <article class="blog-card">
        {/* Background image: 885px × 740px */}
        <div class="blog-card__image">
          <img src={post.image} alt={post.title} loading="lazy" />
        </div>

        {/* White overlay bar: 885px × 180px, positioned at top: 570px */}
        <div class="blog-card__text-bar">
          <div class="blog-card__text-content">
            <h3 class="blog-card__title">{post.title}</h3>
            {post.excerpt && <p class="blog-card__excerpt">{post.excerpt}</p>}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
.blog {
  background: #e8e8e8;
  padding: 0;
}

.blog__cards-container {
  display: flex;
  gap: 50px;
  min-width: 1820px;
  margin-top: 50px;
  padding-left: 50px;
  padding-right: 50px;
}

.blog-card {
  position: relative;
  width: 885px;
  height: 750px;
  flex-shrink: 0;
}

.blog-card__image {
  position: absolute;
  top: 0;
  left: 0;
  width: 885px;
  height: 740px;
  overflow: hidden;
}

.blog-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.blog-card__text-bar {
  position: absolute;
  top: 570px;
  left: 0;
  width: 885px;
  height: 180px;
  background: white;
}

.blog-card__text-content {
  position: absolute;
  left: 39px;
  bottom: calc(41.77% - 44px);
  width: calc(100% - 79px);
  height: 106px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.blog-card__title {
  font-size: 21px;
  font-weight: 700;
  letter-spacing: 1.05px;
  line-height: 32px;
  height: auto;
  color: #000;
  margin: 0;
  padding: 0;
}

.blog-card__excerpt {
  font-size: 17px;
  font-weight: 400;
  letter-spacing: 0.09px;
  line-height: 25px;
  height: auto;
  color: #000;
  margin: 0;
  padding: 0;
}
</style>
