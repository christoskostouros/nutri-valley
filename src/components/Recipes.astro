---
/* Recipes.astro — ΣΥΝΤΑΓΕΣ ΜΕ ΤΑ ΠΡΟΪΟΝΤΑ ΜΑΣ
   Light gray bg, 4 recipe photos (rounded ~20px), dark CTA
*/

const recipes = [
  {
    id: 1,
    title: 'Τηγανητό ρύζι με κοτόπουλο',
    image: '/assets/images/recipe-img-01.webp',
    href: '/syntages/tighanito-ryzi-kotopoulo',
  },
  {
    id: 2,
    title: 'Brownies with a twist',
    image: '/assets/images/recipe-img-02.webp',
    href: '/syntages/brownies-twist',
  },
  {
    id: 3,
    title: 'Ρυζογκοφρέτα με Cottage Cheese, Μέλι και Κανέλα',
    image: '/assets/images/recipe-img-03.webp',
    href: '/syntages/ryzogkofreta-cottage-cheese',
  },
  {
    id: 4,
    title: 'Πέστο κόκκινης πιπεριάς και κοτόπουλο',
    image: '/assets/images/recipe-img-04.webp',
    href: '/syntages/pesto-piperia-kotopoulo',
  },
];
---

<section class="section recipes" aria-labelledby="recipes-title">
  <div class="container">

    <div class="recipes__header">
      <h2 id="recipes-title" class="heading-section">ΣΥΝΤΑΓΕΣ ΜΕ ΤΑ ΠΡΟΪΟΝΤΑ ΜΑΣ</h2>
    </div>

    <div class="recipes__grid">
      {recipes.map((recipe) => (
        <a href={recipe.href} class="recipe-card">
          <div class="recipe-card__img-wrap">
            <img src={recipe.image} alt={recipe.title} loading="lazy" />
          </div>
          <div class="recipe-card__body">
            <h3 class="recipe-card__title">{recipe.title}</h3>
          </div>
        </a>
      ))}
    </div>

    <div style="display:flex; justify-content:center; margin-top:50px;">
      <a href="/syntages" class="btn btn-dark">ΟΛΕΣ ΟΙ ΣΥΝΤΑΓΕΣ</a>
    </div>

  </div>
</section>

<style>
.recipes {
  background: #F7F5F2;
}

.recipes__header {
  text-align: center;
  margin-bottom: 60px;
}

.recipes__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

.recipe-card {
  display: block;
  border-radius: var(--radius-card);
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.recipe-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.12);
}

.recipe-card__img-wrap {
  aspect-ratio: 1 / 1;
  overflow: hidden;
  background: var(--light);
}
.recipe-card__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.recipe-card:hover .recipe-card__img-wrap img {
  transform: scale(1.05);
}

.recipe-card__body {
  padding: 20px 16px 16px;
  background: var(--white);
}

.recipe-card__title {
  font-size: 15px;
  font-weight: 700;
  line-height: 1.4;
  color: var(--dark);
  letter-spacing: 0.5px;
}
</style>
