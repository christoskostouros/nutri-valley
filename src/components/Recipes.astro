---
/* Recipes.astro — ΣΥΝΤΑΓΕΣ ΜΕ ΤΑ ΠΡΟΪΟΝΤΑ ΜΑΣ
   Light gray bg, 4 recipe photos (rounded ~20px), dark CTA
*/

const recipes = [
  {
    id: 1,
    title: 'Τηγανητό ρύζι με κοτόπουλο',
    image: '/assets/images/recipe-img-01.webp',
    href: '/syntages/tighanito-ryzi-kotopoulo',
  },
  {
    id: 2,
    title: 'Brownies with a twist',
    image: '/assets/images/recipe-img-02.webp',
    href: '/syntages/brownies-twist',
  },
  {
    id: 3,
    title: 'Ρυζογκοφρέτα με Cottage Cheese, Μέλι και Κανέλα',
    image: '/assets/images/recipe-img-03.webp',
    href: '/syntages/ryzogkofreta-cottage-cheese',
  },
  {
    id: 4,
    title: 'Πέστο κόκκινης πιπεριάς και κοτόπουλο',
    image: '/assets/images/recipe-img-04.webp',
    href: '/syntages/pesto-piperia-kotopoulo',
  },
];
---

<section class="section recipes" aria-labelledby="recipes-title">
  <div class="overlap-group">

    <h2 id="recipes-title" class="recipes__heading">ΣΥΝΤΑΓΕΣ ΜΕ ΤΑ ΠΡΟΪΟΝΤΑ ΜΑΣ</h2>

    <p class="recipes__subtitle">Εμπνευστείτε από τις συνταγές μας και δημιουργήστε γευστικά και θρεπτικά πιάτα για όλη την οικογένεια με τα προϊόντα Nutri Valley.</p>

    <div class="recipes__cards">
      {recipes.map((recipe, index) => (
        <a href={recipe.href} class="recipe-card" style={index === 0 ? '' : 'margin-left: 50px;'}>
          <div class="recipe-card__image">
            <img src={recipe.image} alt={recipe.title} loading="lazy" />
          </div>
          <div class="recipe-card__bar">
            <h3 class="recipe-card__title">{recipe.title}</h3>
            <svg class="recipe-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <div class="recipes__cta">
      <a href="/syntages" class="btn btn-dark">ΟΛΕΣ ΟΙ ΣΥΝΤΑΓΕΣ</a>
    </div>

  </div>
</section>

<style>
.recipes {
  background: #e8e8e8;
  padding: 0;
}

.overlap-group {
  width: 100%;
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.recipes__heading {
  max-width: 530px;
  width: 100%;
  height: 45px;
  margin-top: 125px;
  text-align: center;
  font-size: 18px;
  font-weight: 600;
  letter-spacing: 1.6px;
  line-height: 38.4px;
  color: var(--dark);
  padding: 0 20px;
}

.recipes__subtitle {
  max-width: 777px;
  width: 100%;
  height: 62px;
  margin-top: 18px;
  text-align: center;
  font-size: 17px;
  font-weight: 400;
  line-height: 26px;
  color: var(--dark);
  opacity: 0.75;
  padding: 0 20px;
}

.recipes__cards {
  display: flex;
  flex-wrap: wrap;
  max-width: 100%;
  margin-top: 79px;
  align-items: flex-start;
  justify-content: flex-start;
  padding: 0 40px;
  gap: 50px;
  width: 100%;
}

.recipe-card {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  max-width: 363px;
  height: 480px;
  border-radius: 0;
  overflow: hidden;
  background: white;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  text-decoration: none;
  color: inherit;
}
.recipe-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
}

.recipe-card__image {
  width: 100%;
  height: calc(100% - 100px);
  overflow: hidden;
  background: var(--light);
  flex-shrink: 0;
}
.recipe-card__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.recipe-card:hover .recipe-card__image img {
  transform: scale(1.05);
}

.recipe-card__bar {
  width: 100%;
  height: 100px;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 8.1%;
  box-sizing: border-box;
  flex-shrink: 0;
}

.recipe-card__title {
  font-size: 17px;
  font-weight: 500;
  line-height: 26px;
  letter-spacing: 0.09px;
  color: var(--dark);
  margin: 0;
  flex: 1;
  width: 72.67%;
}

.recipe-card__arrow {
  width: 2.77%;
  height: 17.22%;
  color: var(--dark);
  flex-shrink: 0;
  margin-left: 12px;
}

.recipes__cta {
  display: flex;
  justify-content: center;
  margin-top: 70px;
  margin-bottom: 100px;
}
</style>
