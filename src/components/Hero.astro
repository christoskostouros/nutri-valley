---
/* Hero.astro — 2 full-bleed slides from XD design
   Each slide is a 1820×750px assembled image from Anima export
   Left text overlay: heading + subtext + dark CTA btn
   group-31@1x.png  = Adults hero slide
   group-31-1@1x.png = Kids hero slide
*/

const slides = [
  {
    id: 1,
    bgImage: '/assets/images/hero-adults.webp',
    heading: 'ΑΠΟΛΑΥΣΗ & ΙΣΟΡΡΟΠΙΑ\nΣΕ ΚΑΘΕ ΕΠΙΛΟΓΗ',
    subtext: 'Θρεπτικές επιλογές σχεδιασμένες για τον σύγχρονο τρόπο ζωής.',
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
    ctaHref: '/proionta',
  },
  {
    id: 2,
    bgImage: '/assets/images/hero-kids.webp',
    heading: 'ΚΑΝΕ ΤΟ ΠΡΩΙΝΟ ΤΟΥΣ...\nΤΗ ΣΤΙΓΜΗ ΤΗΣ ΗΜΕΡΑΣ!',
    subtext: 'Οι ήρωες που αγαπούν τα παιδιά, σε προϊόντα που αγαπούν οι γονείς.',
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
    ctaHref: '/proionta/paidia',
  },
];
---

<section class="hero" aria-label="Hero slider">
  <div class="hero__track" id="hero-track">

    {slides.map((slide, i) => (
      <div class={`hero__slide ${i === 0 ? 'is-active' : ''}`} data-index={i}>
        <!-- Full-bleed background image from Anima export -->
        <img
          src={slide.bgImage}
          alt=""
          class="hero__bg-img"
          width="1820"
          height="750"
          loading={i === 0 ? 'eager' : 'lazy'}
        />

        <!-- Text overlay positioned left as in XD -->
        <div class="hero__content">
          <div class="hero__left">
            <h1 class="heading-hero hero__heading">
              {slide.heading.split('\n').map((line, j) => (
                <span key={j}>{line}<br /></span>
              ))}
            </h1>
            <p class="hero__subtext">{slide.subtext}</p>
            <a href={slide.ctaHref} class="btn btn-dark hero__cta">{slide.ctaText}</a>
          </div>
        </div>
      </div>
    ))}

  </div>

  <!-- Arrows -->
  <button class="slider-arrow hero__arrow hero__arrow--prev" aria-label="Προηγούμενο slide">
    <svg viewBox="0 0 20 20" fill="none"><path d="M13 4L7 10L13 16" stroke="#474444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>
  <button class="slider-arrow hero__arrow hero__arrow--next" aria-label="Επόμενο slide">
    <svg viewBox="0 0 20 20" fill="none"><path d="M7 4L13 10L7 16" stroke="#474444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </button>

  <!-- Dot indicators -->
  <div class="hero__dots" role="tablist" aria-label="Slide navigation">
    {slides.map((_, i) => (
      <button
        class={`hero__dot ${i === 0 ? 'is-active' : ''}`}
        role="tab"
        aria-selected={i === 0}
        aria-label={`Slide ${i + 1}`}
        data-dot={i}
      ></button>
    ))}
  </div>
</section>

<style>
/* ===== HERO ===== */
.hero {
  position: relative;
  width: var(--container);     /* 1820px */
  margin: 0 auto;
  border-radius: var(--radius-hero);
  overflow: hidden;
}

.hero__track {
  position: relative;
  width: 100%;
}

.hero__slide {
  position: relative;
  width: 100%;
  height: 750px;
  display: none;
  overflow: hidden;
}
.hero__slide.is-active { display: block; }

/* Full-bleed assembled hero image (1820×750px from Anima) */
.hero__bg-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

/* Text overlay — left side, matching XD: left:232px, ~33% from top */
.hero__content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  padding: 0 0 0 232px;
}

.hero__left {
  display: flex;
  flex-direction: column;
  gap: 28px;
  max-width: 530px;
}

.hero__heading {
  /* Uses heading-hero: 42px, Bold, #474444, line-height 60px */
}

.hero__subtext {
  font-size: 17px;
  font-weight: 400;
  line-height: 1.6;
  color: var(--dark);
  max-width: 460px;
}

.hero__cta {
  align-self: flex-start;
}

/* Arrows */
.hero__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
}
.hero__arrow--prev { left: 28px; }
.hero__arrow--next { right: 28px; }

/* Dots */
.hero__dots {
  position: absolute;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
  z-index: 4;
}

.hero__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(71,68,68,0.3);
  border: none;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.hero__dot.is-active {
  background: var(--dark);
  transform: scale(1.3);
}
</style>

<script>
const track = document.getElementById('hero-track');
const slides = track?.querySelectorAll('.hero__slide') ?? [];
const dots = document.querySelectorAll('.hero__dot');
const prevBtn = document.querySelector('.hero__arrow--prev');
const nextBtn = document.querySelector('.hero__arrow--next');
let current = 0;

function goTo(n: number) {
  slides[current]?.classList.remove('is-active');
  dots[current]?.classList.remove('is-active');
  dots[current]?.setAttribute('aria-selected', 'false');
  current = (n + slides.length) % slides.length;
  slides[current]?.classList.add('is-active');
  dots[current]?.classList.add('is-active');
  dots[current]?.setAttribute('aria-selected', 'true');
}

prevBtn?.addEventListener('click', () => goTo(current - 1));
nextBtn?.addEventListener('click', () => goTo(current + 1));
dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

// Auto-advance every 5s
setInterval(() => goTo(current + 1), 5000);
</script>
