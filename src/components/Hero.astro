---
/* Hero.astro — Slider section
   XD: W:1820px H:750px, top:170px left:50px
   Background: beige/tan image, border-radius ~24px
   Left: heading 42px + subtext + dark CTA btn 300×70px
   Right: product image
   Slider arrows + dot indicators
*/

const slides = [
  {
    id: 1,
    heading: 'ΑΠΟΛΑΥΣΗ & ΙΣΟΡΡΟΠΙΑ\nΣΕ ΚΑΘΕ ΕΠΙΛΟΓΗ',
    subtext: 'Θρεπτικές επιλογές σχεδιασμένες για τον σύγχρονο τρόπο ζωής.',
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΪΟΝΤΑ',
    ctaHref: '/proionta',
    image: '/assets/images/hero/hero-slide-1.png',
    imageAlt: 'Nutri Valley Granola & Αφράτες Γκοφρέτες',
    bgImage: '/assets/images/hero/hero-bg-1.jpg',
  },
];
---

<section class="hero" aria-label="Hero slider">
  <div class="hero__track" id="hero-track">

    {slides.map((slide, i) => (
      <div class={`hero__slide ${i === 0 ? 'is-active' : ''}`} data-index={i}>
        <div class="hero__bg" style={`background-image: url('${slide.bgImage}')`}></div>

        <div class="hero__content">
          <!-- LEFT -->
          <div class="hero__left">
            <h1 class="heading-hero hero__heading">
              {slide.heading.split('\n').map((line, j) => (
                <span key={j}>{line}<br /></span>
              ))}
            </h1>
            <p class="hero__subtext">{slide.subtext}</p>
            <a href={slide.ctaHref} class="btn btn-dark hero__cta">{slide.ctaText}</a>
          </div>

          <!-- RIGHT: product image -->
          <div class="hero__right">
            <img
              src={slide.image}
              alt={slide.imageAlt}
              class="hero__product-img"
              width="780"
              height="620"
              loading="eager"
            />
          </div>
        </div>

        <!-- Slider arrows -->
        <button class="slider-arrow hero__arrow hero__arrow--prev" aria-label="Προηγούμενο slide">
          <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M13 4L7 10L13 16" stroke="#474444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="slider-arrow hero__arrow hero__arrow--next" aria-label="Επόμενο slide">
          <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7 4L13 10L7 16" stroke="#474444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    ))}

  </div>

  <!-- Dot indicators -->
  <div class="hero__dots" role="tablist" aria-label="Slide navigation">
    {slides.map((_, i) => (
      <button
        class={`hero__dot ${i === 0 ? 'is-active' : ''}`}
        role="tab"
        aria-selected={i === 0}
        aria-label={`Slide ${i + 1}`}
        data-dot={i}
      ></button>
    ))}
  </div>
</section>

<style>
/* ===== HERO ===== */
.hero {
  position: relative;
  width: var(--container);     /* 1820px */
  margin: 0 auto;
  border-radius: var(--radius-hero);
  overflow: hidden;
}

.hero__track {
  position: relative;
  width: 100%;
}

.hero__slide {
  position: relative;
  width: 100%;
  height: 750px;
  display: none;
  overflow: hidden;
}
.hero__slide.is-active { display: flex; }

/* Background */
.hero__bg {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  background-color: var(--beige); /* fallback */
}

/* Content layout */
.hero__content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  width: 100%;
  height: 100%;
  padding: 60px 80px;
  gap: 40px;
}

.hero__left {
  flex: 0 0 520px;
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.hero__heading {
  /* 42px, Bold, #474444, line-height 60px from XD */
}

.hero__subtext {
  font-size: 18px;
  font-weight: 400;
  line-height: 1.6;
  color: var(--dark);
  max-width: 460px;
}

.hero__cta {
  /* btn-dark: 300×70px, #474444, radius 35px */
  align-self: flex-start;
}

.hero__right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero__product-img {
  width: 100%;
  max-width: 780px;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 20px 40px rgba(0,0,0,0.12));
}

/* Arrows */
.hero__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 3;
}
.hero__arrow--prev { left: 28px; }
.hero__arrow--next { right: 28px; }

/* Dots */
.hero__dots {
  position: absolute;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
  z-index: 4;
}

.hero__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: rgba(71,68,68,0.3);
  border: none;
  cursor: pointer;
  transition: background 0.2s, transform 0.2s;
}
.hero__dot.is-active {
  background: var(--dark);
  transform: scale(1.3);
}
</style>
