---
/* About.astro — Dark full-width section with oats image
   Left: white rounded card with heading + checklist + green CTA
   Right: oats/ingredients image
*/

const checklistItems = [
  'Υγιεινές και απολαυστικές επιλογές για όλες τις ηλικίες',
  'Πλούσια γεύση, ισορροπημένα συστατικά',
  'Κατάλληλα για κάθε στιγμή της ημέρας',
  'Ποιοτικά προϊόντα από αξιόπιστες πρώτες ύλες',
  'Παιδικές σειρές με ήρωες που λατρεύουν τα παιδιά',
];
---

<section class="about" aria-labelledby="about-title">
  <!-- Background: dark oats image -->
  <div class="about__bg" style="background-image: url('/assets/images/about/oats-bg.jpg')">

    <div class="container about__inner">

      <!-- White card (left) -->
      <div class="about__card">
        <h2 id="about-title" class="about__heading">
          Η NUTRI VALLEY ΔΗΜΙΟΥΡΓΕΙ ΠΡΟΪΟΝΤΑ
          ΠΟΥ ΚΑΝΟΥΝ ΤΗΝ ΚΑΘΗΜΕΡΙΝΗ ΔΙΑΤΡΟΦΗ
          ΠΙΟ ΕΥΚΟΛΗ, ΠΙΟ ΥΓΙΕΙΝΗ ΚΑΙ ΠΙΟ ΑΠΟΛΑΥΣΤΙΚΗ
          ΓΙΑ ΜΙΚΡΟΥΣ ΚΑΙ ΜΕΓΑΛΟΥΣ.
        </h2>

        <ul class="about__checklist" role="list">
          {checklistItems.map((item) => (
            <li class="about__checklist-item">
              <svg class="about__check" width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M4 10L8.5 14.5L16 6" stroke="#474444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>

        <a href="/sxetika" class="btn btn-green about__cta">ΣΧΕΤΙΚΑ ΜΕ ΕΜΑΣ</a>
      </div>

      <!-- Right: image fills remaining space (bg image does the work) -->
      <div class="about__image-space" aria-hidden="true"></div>

    </div>
  </div>
</section>

<style>
.about {
  width: 100%;
}

.about__bg {
  background-size: cover;
  background-position: center right;
  background-color: #1A1512;   /* dark fallback */
  min-height: 600px;
}

.about__inner {
  display: flex;
  align-items: center;
  min-height: 600px;
  padding-top: 60px;
  padding-bottom: 60px;
  gap: 60px;
}

/* White card */
.about__card {
  flex: 0 0 520px;
  background: var(--white);
  border-radius: var(--radius-card);
  padding: 52px 48px;
  display: flex;
  flex-direction: column;
  gap: 32px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.2);
}

.about__heading {
  font-size: 22px;
  font-weight: 700;
  line-height: 1.5;
  letter-spacing: 1px;
  color: var(--dark);
  text-transform: uppercase;
  white-space: pre-line;
}

.about__checklist {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.about__checklist-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.5;
  color: var(--dark);
}

.about__check {
  flex-shrink: 0;
  margin-top: 2px;
}

.about__cta {
  align-self: flex-start;
}

.about__image-space {
  flex: 1;
}
</style>
