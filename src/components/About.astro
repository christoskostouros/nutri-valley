---
/* About.astro — XD Specs Exact Match
   overlap-group3: background image overlay container, 805px height
   group-65: white card 715×585px with heading, checklist, CTA
   No video element per XD design
*/

const checklistItems = [
  'Υγιεινές και απολαυστικές επιλογές για όλες τις ηλικίες',
  'Πλούσια γεύση, ισορροπημένα συστατικά',
  'Κατάλληλα για κάθε στιγμή της ημέρας',
  'Ποιοτικά προϊόντα από αξιόπιστες πρώτες ύλες',
  'Παιδικές σειρές με ήρωες που λατρεύουν τα παιδιά',
];
---

<section class="about" aria-labelledby="about-title">
  <div class="overlap-group3">
    <!-- White card container (group-65) -->
    <div class="group-65">

      <!-- Heading (nutri-valley) -->
      <h2 id="about-title" class="nutri-valley">
        Η NUTRI VALLEY ΔΗΜΙΟΥΡΓΕΙ ΠΡΟΪΟΝΤΑ
        ΠΟΥ ΚΑΝΟΥΝ ΤΗΝ ΚΑΘΗΜΕΡΙΝΗ ΔΙΑΤΡΟΦΗ
        ΠΙΟ ΕΥΚΟΛΗ, ΠΙΟ ΥΓΙΕΙΝΗ ΚΑΙ ΠΙΟ ΑΠΟΛΑΥΣΤΙΚΗ
        ΓΙΑ ΜΙΚΡΟΥΣ ΚΑΙ ΜΕΓΑΛΟΥΣ.
      </h2>

      <!-- Checklist area (group-64) -->
      <ul class="group-64" role="list">
        {checklistItems.map((item) => (
          <li class="checklist-item">
            <svg class="check-icon" width="17" height="14" viewBox="0 0 17 14" fill="none">
              <path d="M1 7L6 12L16 2" stroke="#90a86d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="check-text">{item}</span>
          </li>
        ))}
      </ul>

      <!-- Green CTA Button (component-5-1) -->
      <a href="/sxetika" class="component-5-1">ΣΧΕΤΙΚΑ ΜΕ ΕΜΑΣ</a>

    </div>
  </div>
</section>

<style>
.about {
  width: 100%;
}

/* overlap-group3 container */
.overlap-group3 {
  background-image: url(/assets/images/about-bg.webp);
  background-position: 50% 50%;
  background-size: cover;
  background-repeat: no-repeat;
  height: 805px;
  margin-top: 50px;
  min-width: 1820px;
  padding: 109.6px 110px;
  display: flex;
  align-items: flex-end;
}

/* White card (group-65) */
.group-65 {
  background-color: #ffffff;
  border-radius: 20px;
  height: 585px;
  width: 715px;
  position: relative;
  padding: 0;
}

/* Heading (nutri-valley) — positioned absolutely */
.nutri-valley {
  position: absolute;
  left: 60px;
  top: 65px;
  height: 126px;
  width: 515px;

  font-size: 21px;
  font-weight: bold;
  letter-spacing: 1.05px;
  line-height: 32px;
  color: #474444;

  white-space: pre-line;
  margin: 0;
  padding: 0;
}

/* Checklist area (group-64) */
.group-64 {
  position: absolute;
  left: 62px;
  bottom: calc(41.83% - 81px);
  height: 194px;
  width: calc(100% - 147px);

  list-style: none;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  margin: 0;
  padding: 0;
}

/* Individual checklist item */
.checklist-item {
  display: flex;
  align-items: flex-start;
  gap: 0;
}

/* Checkmark icon */
.check-icon {
  flex-shrink: 0;
  width: 17px;
  height: 14px;
  margin-right: 36px;
}

/* Checklist item text */
.check-text {
  font-size: 17px;
  font-weight: 400;
  letter-spacing: 0.09px;
  line-height: 40px;
  color: #474444;
}

/* Green CTA button (component-5-1) */
.component-5-1 {
  position: absolute;
  bottom: 60px;
  left: 62px;

  width: 300px;
  height: 70px;
  background-color: #90a86d;
  background-image: url(/assets/images/cta-dark-texture.webp);
  background-size: cover;
  border-radius: 35px;
  border: none;

  display: flex;
  align-items: center;
  justify-content: center;

  font-size: 16px;
  font-weight: bold;
  letter-spacing: 1.6px;
  color: #ffffff;
  text-decoration: none;
  text-transform: uppercase;

  cursor: pointer;
  transition: all 0.3s ease;
}

.component-5-1:hover {
  opacity: 0.95;
  transform: translateY(-2px);
}

.component-5-1:active {
  transform: translateY(0);
}
</style>
