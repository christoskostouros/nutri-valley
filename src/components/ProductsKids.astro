---
/* ProductsKids.astro — ΠΑΙΔΙΚΑ ΠΡΟΪΟΝΤΑ
   3 large brand cards: Peppa Pig (pink), PJ Masks (green), Minions (yellow)
   Each: brand logo + floating product images + white pill CTA button
*/

const brands = [
  {
    id: 'brand-1',
    name: 'Peppa Pig',
    href: '/proionta/paidia',
    image: '/assets/images/kids-banner-01.webp',
    bgColor: '#F2C8D0',   /* Peppa Pig pink */
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
  },
  {
    id: 'brand-2',
    name: 'PJ Masks',
    href: '/proionta/paidia',
    image: '/assets/images/kids-banner-02.webp',
    bgColor: '#5A9160',   /* PJ Masks green */
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
  },
  {
    id: 'brand-3',
    name: 'Minions',
    href: '/proionta/paidia',
    image: '/assets/images/kids-banner-03.webp',
    bgColor: '#F2CB55',   /* Minions yellow */
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
  },
];
---

<section class="section products-kids" aria-labelledby="kids-title">
  <div class="container">

    <div class="products-kids__header">
      <h2 id="kids-title" class="heading-section">ΠΑΙΔΙΚΑ ΠΡΟΪΟΝΤΑ</h2>
      <p class="section-subtitle">Αγαπημένοι ήρωες, υγιεινές γεύσεις! Προϊόντα σχεδιασμένα ειδικά για παιδιά, με τους αγαπημένους τους χαρακτήρες και πλούσια διατροφική αξία.</p>
    </div>

    <div class="kids-cards">
      {brands.map((brand) => (
        <div class="kids-card" style={`--kids-bg: ${brand.bgColor}`}>
          <!-- Full-bleed banner image -->
          <div class="kids-card__img-wrap">
            <img src={brand.image} alt={`${brand.name} προϊόντα`} class="kids-card__img" loading="lazy" />
          </div>

          <!-- CTA button overlaid at bottom -->
          <div class="kids-card__footer">
            <a href={brand.href} class="btn btn-white-pill kids-card__btn">{brand.ctaText}</a>
          </div>
        </div>
      ))}

      <!-- Carousel arrow for overflow on smaller screens -->
      <button class="slider-arrow kids-cards__arrow" aria-label="Επόμενο">
        <svg viewBox="0 0 20 20" fill="none"><path d="M7 4L13 10L7 16" stroke="#474444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

  </div>
</section>

<style>
.products-kids {
  background: var(--white);
}

.products-kids__header {
  text-align: center;
  margin-bottom: 60px;
}

.section-subtitle {
  font-size: 17px;
  font-weight: 400;
  line-height: 1.6;
  color: var(--dark);
  opacity: 0.75;
  max-width: 700px;
  margin: 20px auto 0;
}

.kids-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  position: relative;
}

.kids-card {
  background: var(--kids-bg);
  border-radius: var(--radius-card);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 520px;
  position: relative;
  transition: transform 0.3s ease;
}
.kids-card:hover { transform: translateY(-6px); }

/* Full-bleed image fills the entire card */
.kids-card__img-wrap {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  overflow: hidden;
}
.kids-card__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}

/* Button at bottom on top of image */
.kids-card__footer {
  position: relative;
  z-index: 2;
  width: 100%;
  margin-top: auto;
  padding: 28px 24px 32px;
  display: flex;
  justify-content: center;
  /* push to bottom */
  align-self: flex-end;
  min-height: 92px;
}

.kids-cards__arrow {
  position: absolute;
  right: -26px;
  top: 50%;
  transform: translateY(-50%);
  display: none;  /* shows on tablet/mobile */
}
</style>
