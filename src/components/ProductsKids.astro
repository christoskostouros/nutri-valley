---
/* ProductsKids.astro — ΠΑΙΔΙΚΑ ΠΡΟΪΟΝΤΑ
   XD: 4 cards, each 573×740px
   - Full-bleed background image (group-52, 54, 56, 99 from Anima)
   - Brand logo centered at top ~60px from top
   - White pill CTA button at bottom (calc(100%-40px) wide, 70px tall, radius 35px)
*/

const brands = [
  {
    id: 'brand-1',
    name: 'Brand 1',
    href: '/proionta/paidia',
    bgImage: '/assets/images/kids-card-01.webp',
    logo:    '/assets/images/kids-logo-01.webp',
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
  },
  {
    id: 'brand-2',
    name: 'Brand 2',
    href: '/proionta/paidia',
    bgImage: '/assets/images/kids-card-02.webp',
    logo:    '/assets/images/kids-logo-02.webp',
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
  },
  {
    id: 'brand-3',
    name: 'Brand 3',
    href: '/proionta/paidia',
    bgImage: '/assets/images/kids-card-03.webp',
    logo:    '/assets/images/kids-logo-03.webp',
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
  },
  {
    id: 'brand-4',
    name: 'Brand 4',
    href: '/proionta/paidia',
    bgImage: '/assets/images/kids-card-04.webp',
    logo:    '/assets/images/kids-logo-04.webp',
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
  },
];
---

<section class="section products-kids" aria-labelledby="kids-title">
  <div class="container">

    <div class="products-kids__header">
      <h2 id="kids-title" class="heading-section">ΠΑΙΔΙΚΑ ΠΡΟΪΟΝΤΑ</h2>
      <p class="section-subtitle">Αγαπημένοι ήρωες, υγιεινές γεύσεις! Προϊόντα σχεδιασμένα ειδικά για παιδιά, με τους αγαπημένους τους χαρακτήρες και πλούσια διατροφική αξία.</p>
    </div>

    <!-- 4 brand cards in a row, scrollable -->
    <div class="kids-cards">
      {brands.map((brand) => (
        <div class="kids-card">
          <!-- Full-bleed assembled card image from Anima (573×740px) -->
          <img src={brand.bgImage} alt={`${brand.name} προϊόντα`} class="kids-card__bg" loading="lazy" />

          <!-- Brand logo top-center (rectangle-52 etc. from Anima) -->
          <div class="kids-card__logo-wrap">
            <img src={brand.logo} alt="" class="kids-card__logo" loading="lazy" />
          </div>

          <!-- White pill CTA at bottom (matches XD: left:20px bottom:20px w:calc(100%-40px) h:70px radius:35px) -->
          <a href={brand.href} class="kids-card__cta">
            {brand.ctaText}
          </a>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
.products-kids {
  background: var(--white);
}

.products-kids__header {
  text-align: center;
  margin-bottom: 60px;
}

.section-subtitle {
  font-size: 17px;
  font-weight: 400;
  line-height: 1.6;
  color: var(--dark);
  opacity: 0.75;
  max-width: 700px;
  margin: 20px auto 0;
}

/* 4-column grid, scroll on overflow */
.kids-cards {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
  overflow-x: auto;
  scrollbar-width: none;
}
.kids-cards::-webkit-scrollbar { display: none; }

/* Card container — relative so we can overlay logo + cta on the bg image */
.kids-card {
  position: relative;
  border-radius: 24px;
  overflow: hidden;
  aspect-ratio: 573 / 740;  /* matches Anima card dimensions */
  transition: transform 0.3s ease;
  flex-shrink: 0;
}
.kids-card:hover { transform: translateY(-6px); }

/* Full-bleed assembled card image */
.kids-card__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Brand logo — top-center, ~60px from top, matches Anima: top:60px centered */
.kids-card__logo-wrap {
  position: absolute;
  top: 8%;   /* ~60/740 */
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  z-index: 2;
}
.kids-card__logo {
  max-width: 50%;
  height: auto;
  object-fit: contain;
}

/* White pill CTA — bottom, matches XD: left:20px bottom:20px w:calc(100%-40px) h:70px radius:35px */
.kids-card__cta {
  position: absolute;
  left: 20px;
  right: 20px;
  bottom: 20px;
  height: 70px;
  border-radius: 35px;
  background: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 1.6px;
  color: var(--dark);
  text-transform: uppercase;
  text-decoration: none;
  z-index: 3;
  transition: background 0.2s, color 0.2s;
}
.kids-card__cta:hover {
  background: var(--dark);
  color: var(--white);
}
</style>
