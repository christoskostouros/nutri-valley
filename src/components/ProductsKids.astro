---
/* ProductsKids.astro — ΠΑΙΔΙΚΑ ΠΡΟΪΟΝΤΑ
   3 large brand cards: Peppa Pig (pink), PJ Masks (green), Minions (yellow)
   Each: brand logo + floating product images + white pill CTA button
*/

const brands = [
  {
    id: 'brand-1',
    name: 'Παιδικά Προϊόντα 1',
    href: '/proionta/paidia',
    image: '/assets/images/kids-banner-01.webp',
    bgColor: '#C4B2A3',
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
  },
  {
    id: 'brand-2',
    name: 'Παιδικά Προϊόντα 2',
    href: '/proionta/paidia',
    image: '/assets/images/kids-banner-02.webp',
    bgColor: '#859E66',
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
  },
  {
    id: 'brand-3',
    name: 'Παιδικά Προϊόντα 3',
    href: '/proionta/paidia',
    image: '/assets/images/kids-banner-03.webp',
    bgColor: '#E8DDD0',
    ctaText: 'ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ',
  },
];
---

<section class="section products-kids" aria-labelledby="kids-title">
  <div class="container">

    <div class="products-kids__header">
      <h2 id="kids-title" class="heading-section">ΠΑΙΔΙΚΑ ΠΡΟΪΟΝΤΑ</h2>
    </div>

    <div class="kids-cards">
      {brands.map((brand) => (
        <div class="kids-card" style={`--kids-bg: ${brand.bgColor}`}>
          <!-- Full banner image -->
          <div class="kids-card__img-wrap">
            <img src={brand.image} alt={`${brand.name} προϊόντα`} class="kids-card__img" loading="lazy" />
          </div>

          <!-- CTA button -->
          <div class="kids-card__footer">
            <a href={brand.href} class="btn btn-white-pill kids-card__btn">{brand.ctaText}</a>
          </div>
        </div>
      ))}

      <!-- Carousel arrow for overflow on smaller screens -->
      <button class="slider-arrow kids-cards__arrow" aria-label="Επόμενο">
        <svg viewBox="0 0 20 20" fill="none"><path d="M7 4L13 10L7 16" stroke="#474444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

  </div>
</section>

<style>
.products-kids {
  background: var(--white);
}

.products-kids__header {
  text-align: center;
  margin-bottom: 60px;
}

.kids-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
  position: relative;
}

.kids-card {
  background: var(--kids-bg);
  border-radius: var(--radius-card);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 520px;
  position: relative;
  padding: 40px 32px 0;
  transition: transform 0.3s ease;
}
.kids-card:hover { transform: translateY(-6px); }

.kids-card__logo-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 70px;
  margin-bottom: 20px;
}
.kids-card__logo {
  max-height: 60px;
  max-width: 200px;
  object-fit: contain;
}

.kids-card__img-wrap {
  flex: 1;
  width: 100%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  min-height: 280px;
  overflow: visible;
}
.kids-card__img {
  max-width: 320px;
  width: 100%;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 12px 24px rgba(0,0,0,0.15));
}

.kids-card__footer {
  width: 100%;
  padding: 28px 0 32px;
  display: flex;
  justify-content: center;
  background: inherit;
}

.kids-cards__arrow {
  position: absolute;
  right: -26px;
  top: 50%;
  transform: translateY(-50%);
  display: none;  /* shows on tablet/mobile */
}
</style>
