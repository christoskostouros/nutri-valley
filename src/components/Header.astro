---
/* Header.astro — Pixel-perfect from XD specs
   Fixed gradient header with absolute-positioned navbar elements
*/
---

<header class="header">
  <!-- Gradient background -->
  <div class="header__gradient"></div>

  <!-- Navbar bar container -->
  <div class="header__navbar">
    
    <!-- GREEN ΠΡΟΪΟΝΤΑ button (absolute left) -->
    <button class="header__products-btn" aria-label="Προϊόντα menu">
      <svg class="header__hamburger" width="20" height="14" viewBox="0 0 20 14" fill="none">
        <rect width="20" height="2" rx="1" fill="currentColor"/>
        <rect y="6" width="20" height="2" rx="1" fill="currentColor"/>
        <rect y="12" width="20" height="2" rx="1" fill="currentColor"/>
      </svg>
      <span>ΠΡΟΪΟΝΤΑ</span>
    </button>

    <!-- WHITE PILL container (absolute) -->
    <div class="header__pill">
      
      <!-- Logo inside pill -->
      <a href="/" class="header__logo" aria-label="Nutri Valley - Αρχική">
        <img src="/assets/images/nutri-valley-logo.svg" alt="Nutri Valley" width="217" height="45" />
      </a>

      <!-- Nav links inside pill -->
      <nav class="header__nav" aria-label="Main navigation">
        <a href="/syntages" class="nav-link">ΣΥΝΤΑΓΕΣ</a>
        <a href="/diagwnismoi" class="nav-link">ΔΙΑΓΩΝΙΣΜΟΙ</a>
        <a href="/events" class="nav-link">EVENTS</a>
        <a href="/blog" class="nav-link">BLOG</a>
        <a href="/sxetika" class="nav-link">ΣΧΕΤΙΚΑ</a>
        <a href="/epikoinwnia" class="nav-link">ΕΠΙΚΟΙΝΩΝΙΑ</a>
      </nav>

      <!-- RIGHT ICONS (two circles) inside pill -->
      <div class="header__icons">
        <!-- Search circle (globe) -->
        <button class="header__icon-circle header__icon-globe" aria-label="Αλλαγή γλώσσας">
          <svg width="23" height="23" viewBox="0 0 26 26" fill="none">
            <circle cx="13" cy="13" r="11.5" stroke="#474444" stroke-width="1.5"/>
            <ellipse cx="13" cy="13" rx="5.5" ry="11.5" stroke="#474444" stroke-width="1.5"/>
            <line x1="2" y1="9.5" x2="24" y2="9.5" stroke="#474444" stroke-width="1.5"/>
            <line x1="2" y1="16.5" x2="24" y2="16.5" stroke="#474444" stroke-width="1.5"/>
          </svg>
        </button>
        <!-- Language/search circle (magnifier) -->
        <button class="header__icon-circle header__icon-search" aria-label="Αναζήτηση">
          <svg width="17" height="17" viewBox="0 0 26 26" fill="none">
            <circle cx="11" cy="11" r="8.5" stroke="#474444" stroke-width="1.5"/>
            <line x1="17.5" y1="17.5" x2="24" y2="24" stroke="#474444" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

    </div>

  </div>
</header>

<!-- MEGA MENU (from XD menu-desktop-1 / menu-desktop-2) — hidden by default -->
<div class="mega-menu" id="mega-menu" aria-hidden="true">
  <div class="mega-menu__overlay"></div>
  <div class="mega-menu__panel">

    <!-- LEFT: tagline + nav links -->
    <div class="mega-menu__left">
      <p class="mega-menu__tagline">ΑΠΟΛΑΥΣΗ &amp; ΙΣΟΡΡΟΠΙΑ</p>
      <p class="mega-menu__subtitle">Θρεπτικές επιλογές σχεδιασμένες για τον σύγχρονο τρόπο ζωής.</p>
      <a href="/proionta" class="btn btn-dark mega-menu__all-btn">ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ</a>

      <div class="mega-menu__categories">
        <button class="mega-menu__cat mega-menu__cat--active" data-cat="adults">
          ΠΡΟΪΟΝΤΑ ΓΙΑ ΕΝΗΛΙΚΕΣ
          <svg width="7" height="11" viewBox="0 0 7 11" fill="none"><path d="M1 1L6 5.5L1 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="mega-menu__cat" data-cat="kids">
          ΠΑΙΔΙΚΑ ΠΡΟΪΟΝΤΑ
          <svg width="7" height="11" viewBox="0 0 7 11" fill="none"><path d="M1 1L6 5.5L1 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>

    <!-- RIGHT: product thumbnails -->
    <div class="mega-menu__right">

      <!-- ADULTS products (default visible) -->
      <div class="mega-menu__products mega-menu__products--adults is-active" id="menu-adults">
        <a href="/proionta/konserves" class="mega-menu__product-card">
          <div class="mega-menu__product-img">
            <img src="/assets/images/menu/menu-adults-01.webp" alt="Premium Κονσέρβες" loading="lazy" />
          </div>
          <div class="mega-menu__product-logo">
            <img src="/assets/images/menu/menu-logo-01.webp" alt="" loading="lazy" />
          </div>
        </a>
        <a href="/proionta/mpares" class="mega-menu__product-card">
          <div class="mega-menu__product-img">
            <img src="/assets/images/menu/menu-adults-02.webp" alt="Μπάρες Πρωτεΐνης" loading="lazy" />
          </div>
          <div class="mega-menu__product-logo">
            <img src="/assets/images/menu/menu-logo-02.webp" alt="" loading="lazy" />
          </div>
        </a>
        <a href="/proionta/gkofretes" class="mega-menu__product-card">
          <div class="mega-menu__product-img">
            <img src="/assets/images/menu/menu-adults-03.webp" alt="Γκοφρέτες" loading="lazy" />
          </div>
          <div class="mega-menu__product-logo">
            <img src="/assets/images/menu/menu-logo-03.webp" alt="" loading="lazy" />
          </div>
        </a>
        <a href="/proionta/taxini" class="mega-menu__product-card">
          <div class="mega-menu__product-img">
            <img src="/assets/images/menu/menu-adults-04.webp" alt="Ταχίνι" loading="lazy" />
          </div>
          <div class="mega-menu__product-logo">
            <img src="/assets/images/menu/menu-logo-04.webp" alt="" loading="lazy" />
          </div>
        </a>
      </div>

      <!-- KIDS products (hidden, shown on hover) -->
      <div class="mega-menu__products mega-menu__products--kids" id="menu-kids">
        <a href="/proionta/granola" class="mega-menu__product-card mega-menu__product-card--text">
          <span>Γκρανόλα</span>
        </a>
        <a href="/proionta/vromh" class="mega-menu__product-card mega-menu__product-card--text">
          <span>Νιφάδες Βρώμης</span>
        </a>
        <a href="/proionta/kalamboki" class="mega-menu__product-card mega-menu__product-card--text">
          <span>Νιφάδες Καλαμποκιού</span>
        </a>
      </div>

    </div>
  </div>
</div>

<style>
/* ===== HEADER ===== */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 7;
  width: 1920px;
  height: 260px;
}

/* Gradient background (group-117) */
.header__gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 260px;
  background: linear-gradient(180deg, #e8e8e8 0%, rgba(232, 232, 232, 0) 100%);
  width: 100%;
  pointer-events: none;
}

/* Navbar bar (navbar-1) — relative for absolute positioning of children */
.header__navbar {
  position: relative;
  height: 70px;
  margin-left: 50px;
  margin-right: 50px;
  margin-top: 21px;
  flex: 1;
}

/* Green ΠΡΟΪΟΝΤΑ button (rectangle-33) — absolute left */
.header__products-btn {
  position: absolute;
  left: 0;
  top: 0;
  width: 200px;
  height: 100%;
  background-color: #859e66;
  border-radius: 35px;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0;
  padding-left: 26px;
  font-size: 17px;
  font-weight: 700;
  letter-spacing: 1.7px;
  color: #fdfffd;
  transition: background 0.2s;
}
.header__products-btn:hover {
  background-color: #7a8d5a;
}

.header__hamburger {
  width: 20px;
  height: 14px;
  flex-shrink: 0;
}

.header__products-btn span {
  margin-left: 8px;
}

/* White pill container (rectangle-32) — absolute, calc width */
.header__pill {
  position: absolute;
  left: 215px;
  top: 1px;
  width: calc(100% - 380px);
  height: 100%;
  background-color: #fdfffd;
  border-radius: 35px;
  display: flex;
  align-items: center;
  gap: 0;
}

/* Logo inside pill (group-34) — absolute positioned */
.header__logo {
  position: absolute;
  left: 230px;
  top: calc(50% - 22.5px);
  height: 45px;
  width: 217px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
}
.header__logo img {
  height: 45px;
  width: auto;
}

/* Nav links — positioned absolutely inside pill */
.header__nav {
  position: absolute;
  bottom: calc(47.96% - 12px);
  display: flex;
  align-items: center;
  gap: 0;
}

.nav-link {
  position: absolute;
  bottom: 0;
  font-size: 17px;
  font-weight: 700;
  letter-spacing: 1.7px;
  line-height: 20.4px;
  color: #474444;
  text-decoration: none;
  transition: color 0.2s;
  white-space: nowrap;
}
.nav-link:hover {
  color: #859e66;
}

/* Nav link positioning from XD specs */
.nav-link:nth-child(1) {
  /* ΣΥΝΤΑΓΕΣ */
  right: calc(49.98% - 45px);
  width: 90px;
}
.nav-link:nth-child(2) {
  /* ΔΙΑΓΩΝΙΣΜΟΙ */
  right: calc(41.11% - 51px);
  width: 125px;
}
.nav-link:nth-child(3) {
  /* EVENTS */
  right: calc(33.45% - 23px);
  width: 69px;
}
.nav-link:nth-child(4) {
  /* BLOG */
  right: calc(28.09% - 14px);
  width: 49px;
}
.nav-link:nth-child(5) {
  /* ΣΧΕΤΙΚΑ */
  right: calc(22.09% - 16px);
  width: 74px;
}
.nav-link:nth-child(6) {
  /* ΕΠΙΚΟΙΝΩΝΙΑ */
  right: 217px;
  width: 125px;
}

/* Right icons container — absolute positioning */
.header__icons {
  position: absolute;
  right: 0;
  top: 0;
  height: 100%;
  display: flex;
  align-items: center;
  gap: 0;
}

/* Icon circles */
.header__icon-circle {
  position: absolute;
  top: 0;
  width: 70px;
  height: 100%;
  background-color: #fdfffd;
  border-radius: 35px;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: background 0.2s;
}
.header__icon-circle:hover {
  background-color: #f5f5f5;
}

/* Globe icon (search circle) — ellipse-11 */
.header__icon-globe {
  right: 81px;
}
.header__icon-globe svg {
  position: absolute;
  right: 23px;
  width: 23px;
  height: 23px;
}

/* Search icon (language/search circle) — ellipse-9 */
.header__icon-search {
  right: 0;
}
.header__icon-search svg {
  position: absolute;
  right: 27px;
  width: 17px;
  height: 17px;
}

/* ===== MEGA MENU ===== */
.mega-menu {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 99;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.25s ease;
}
.mega-menu.is-open {
  opacity: 1;
  pointer-events: auto;
}

/* Dark overlay behind panel */
.mega-menu__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.3);
}

/* White rounded panel */
.mega-menu__panel {
  position: absolute;
  top: 50px;
  left: 50px;
  right: 50px;
  margin-top: 120px;
  background: var(--white);
  border-radius: 42px;
  display: flex;
  align-items: stretch;
  min-height: 450px;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(0,0,0,0.15);
  transform: translateY(-10px);
  transition: transform 0.25s ease;
}
.mega-menu.is-open .mega-menu__panel {
  transform: translateY(0);
}

/* LEFT side */
.mega-menu__left {
  flex: 0 0 400px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  padding: 50px 48px 50px 60px;
  border-right: 2px solid #e8e8e8;
}

.mega-menu__tagline {
  font-size: 32px;
  font-weight: 700;
  letter-spacing: 2px;
  line-height: 1.3;
  color: var(--dark);
  text-transform: uppercase;
}

.mega-menu__subtitle {
  font-size: 15px;
  line-height: 1.6;
  color: var(--dark);
  opacity: 0.7;
  max-width: 300px;
}

.mega-menu__all-btn {
  align-self: flex-start;
  margin-top: 4px;
}

.mega-menu__categories {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 8px;
}

.mega-menu__cat {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 20px;
  border-radius: 25px;
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: 1.8px;
  color: var(--dark);
  text-transform: uppercase;
  text-align: left;
  width: 100%;
  transition: background 0.2s, color 0.2s;
}
.mega-menu__cat:hover {
  background: #f0f0f0;
}
.mega-menu__cat--active {
  background: #e8e8e8;
  color: var(--dark);
}

/* RIGHT side: product thumbnails */
.mega-menu__right {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 30px 40px;
  overflow: hidden;
}

.mega-menu__products {
  display: none;
  gap: 20px;
  width: 100%;
}
.mega-menu__products.is-active {
  display: flex;
}

/* Thumbnail card */
.mega-menu__product-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  flex: 1;
  transition: transform 0.2s;
}
.mega-menu__product-card:hover {
  transform: translateY(-4px);
}

.mega-menu__product-img {
  width: 100%;
  aspect-ratio: 4/5;
  border-radius: 16px;
  overflow: hidden;
  background: var(--light);
  max-height: 310px;
}
.mega-menu__product-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.mega-menu__product-logo {
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.mega-menu__product-logo img {
  max-height: 50px;
  max-width: 130px;
  object-fit: contain;
}

/* Kids products as text list */
.mega-menu__product-card--text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0;
  flex: 0 0 auto;
  padding: 20px 24px;
  border-radius: 16px;
  background: var(--light);
  min-width: 200px;
  font-size: 18px;
  font-weight: 700;
  letter-spacing: 1px;
  color: var(--dark);
  transition: background 0.2s, color 0.2s;
}
.mega-menu__product-card--text:hover {
  background: var(--green);
  color: var(--white);
  transform: translateY(-4px);
}
</style>

<script>
/* Toggle mega menu on ΠΡΟΪΟΝΤΑ button click */
const btn = document.querySelector('.header__products-btn') as HTMLButtonElement;
const menu = document.getElementById('mega-menu');
const overlay = menu?.querySelector('.mega-menu__overlay');

function openMenu() {
  menu?.classList.add('is-open');
  menu?.setAttribute('aria-hidden', 'false');
}
function closeMenu() {
  menu?.classList.remove('is-open');
  menu?.setAttribute('aria-hidden', 'true');
}

btn?.addEventListener('click', () => {
  if (menu?.classList.contains('is-open')) {
    closeMenu();
  } else {
    openMenu();
  }
});

/* Close on overlay click */
overlay?.addEventListener('click', closeMenu);

/* Close on Escape */
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') closeMenu();
});

/* Category tabs */
const catBtns = document.querySelectorAll('.mega-menu__cat');
catBtns.forEach(catBtn => {
  catBtn.addEventListener('click', () => {
    const cat = (catBtn as HTMLElement).dataset.cat;
    catBtns.forEach(b => b.classList.remove('mega-menu__cat--active'));
    catBtn.classList.add('mega-menu__cat--active');

    document.querySelectorAll('.mega-menu__products').forEach(panel => {
      panel.classList.remove('is-active');
    });
    const target = document.getElementById(`menu-${cat}`);
    target?.classList.add('is-active');
  });
});
</script>
