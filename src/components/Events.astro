---
/* Events.astro — Η NUTRI VALLEY ΤΑΞΙΔΕΥΕΙ ΠΑΝΤΟΥ
   XD Specs: 1920px × 805px with texture overlay
   Text and photos positioned absolutely per XD coordinates
*/
---

<section class="events" aria-labelledby="events-title">
  <!-- Texture overlay -->
  <div class="events__texture"></div>

  <!-- Text content - absolutely positioned -->
  <div class="events__content">
    <h2 id="events-title" class="events__heading">
      Η NUTRI VALLEY ΤΑΞΙΔΕΥΕΙ ΠΑΝΤΟΥ.<br/>
      ΕΛΑΤΕ ΝΑ ΓΝΩΡΙΣΤΟΥΜΕ ΣΕ<br/>
      ΚΑΠΟΙΟ EVENT ΜΑΣ!
    </h2>

    <div class="events__subtitle">
      Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
    </div>

    <a href="/events" class="events__cta">ΟΛΑ ΤΑ EVENTS</a>
  </div>

  <!-- Photos container - absolutely positioned -->
  <div class="events__photos" aria-hidden="true">
    <!-- Back photo -->
    <div class="events__photo events__photo--back">
      <img src="/assets/images/event-photo-01.webp" alt="" loading="lazy" />
    </div>

    <!-- Mid photo -->
    <div class="events__photo events__photo--mid">
      <img src="/assets/images/event-photo-02.webp" alt="" loading="lazy" />
    </div>

    <!-- Front photo -->
    <div class="events__photo events__photo--front">
      <img src="/assets/images/event-photo-03.webp" alt="Nutri Valley event" loading="lazy" />
    </div>
  </div>
</section>

<style>
/* Section: 1920px × 805px with margin-top 200px */
.events {
  position: relative;
  width: 1920px;
  height: 805px;
  margin-top: 200px;
  background-color: #c4b2a3;
  overflow: hidden;
}

/* Texture overlay: group-67 */
.events__texture {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 805px;
  background-image: url(/assets/images/events-texture.webp);
  background-size: cover;
  background-position: 50% 50%;
  mix-blend-mode: multiply;
  opacity: 0.5;
  pointer-events: none;
}

/* Text content - absolutely positioned */
.events__content {
  position: absolute;
  left: 415px;
  top: 247px;
  width: 523px;
  z-index: 10;
}

/* Heading: nutri-valley-1 */
.events__heading {
  width: 523px;
  height: 74px;
  font-size: 21px;
  font-weight: 700;
  line-height: 32px;
  letter-spacing: 1.05px;
  color: #474444;
  margin: 0;
  padding: 0;
}

/* Subtitle: lorem-ipsum-dolor-si-4 */
.events__subtitle {
  position: absolute;
  left: 0;
  top: 84px;
  width: 523px;
  height: 115px;
  font-size: 17px;
  font-weight: 400;
  line-height: 25px;
  color: #474444;
}

/* CTA button: component-8-1 */
.events__cta {
  position: absolute;
  left: 0;
  top: 229px;
  width: 300px;
  height: 70px;
  background-color: #fdfffd;
  background-image: url(/assets/images/events-texture.webp);
  background-size: cover;
  background-position: 50% 50%;
  border: none;
  border-radius: 35px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  color: #474444;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.3s ease;
}

.events__cta:hover {
  background-color: #f5f5f5;
  transform: translateY(-2px);
}

/* Photos container: component-7-1 */
.events__photos {
  position: absolute;
  left: 1016px;
  top: 148px;
  width: 518px;
  height: 515px;
  z-index: 5;
}

/* Photo base styles */
.events__photo {
  position: absolute;
  border-radius: 20px;
  overflow: hidden;
  background-size: cover;
  background-position: center;
}

.events__photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Back photo: group-71/group-70 */
.events__photo--back {
  left: 0;
  top: 0;
  width: 470px;
  height: 515px;
  z-index: 1;
}

/* Mid photo: group-73/group-72 */
.events__photo--mid {
  right: 0;
  top: 24px;
  width: 392px;
  height: 468px;
  z-index: 2;
}

/* Front photo: group-75/group-74 */
.events__photo--front {
  right: 77px;
  top: 45px;
  width: 324px;
  height: 418px;
  z-index: 3;
}
</style>
