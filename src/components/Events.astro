---
/* Events.astro — Η NUTRI VALLEY ΤΑΞΙΔΕΥΕΙ ΠΑΝΤΟΥ
   Beige paper-texture background
   Text left + stacked event photos right
   White outline button "ΟΛΑ ΤΑ EVENTS"
*/
---

<section class="events" aria-labelledby="events-title">
  <div class="events__bg">
    <div class="container events__inner">

      <!-- LEFT: text content -->
      <div class="events__content">
        <h2 id="events-title" class="events__heading">
          Η NUTRI VALLEY ΤΑΞΙΔΕΥΕΙ ΠΑΝΤΟΥ.<br/>
          ΕΛΑΤΕ ΝΑ ΓΝΩΡΙΣΤΟΥΜΕ ΣΕ<br/>
          ΚΑΠΟΙΟ EVENT ΜΑΣ!
        </h2>
        <a href="/events" class="btn btn-outline-dark events__cta">ΟΛΑ ΤΑ EVENTS</a>
      </div>

      <!-- RIGHT: stacked event photos -->
      <div class="events__photos" aria-hidden="true">
        <div class="events__photo events__photo--back">
          <img src="/assets/images/event-photo-01.webp" alt="" loading="lazy" />
        </div>
        <div class="events__photo events__photo--mid">
          <img src="/assets/images/event-photo-02.webp" alt="" loading="lazy" />
        </div>
        <div class="events__photo events__photo--front">
          <img src="/assets/images/event-photo-03.webp" alt="Nutri Valley event" loading="lazy" />
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.events {
  width: 100%;
}

.events__bg {
  background-color: #E8DDD0;
  min-height: 560px;
}

.events__inner {
  display: flex;
  align-items: center;
  gap: 80px;
  min-height: 560px;
  padding-top: 80px;
  padding-bottom: 80px;
}

.events__content {
  flex: 0 0 560px;
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.events__heading {
  font-size: 28px;
  font-weight: 700;
  line-height: 1.5;
  letter-spacing: 1.5px;
  color: var(--dark);
  text-transform: uppercase;
}

.events__subtext {
  font-size: 16px;
  line-height: 1.7;
  color: var(--dark);
  max-width: 480px;
}

.events__cta {
  align-self: flex-start;
}

/* Stacked photos */
.events__photos {
  flex: 1;
  position: relative;
  height: 460px;
  min-width: 460px;
}

.events__photo {
  position: absolute;
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: 0 12px 40px rgba(0,0,0,0.25);
}
.events__photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Back photo: widest, slightly rotated right, top */
.events__photo--back {
  width: 380px;
  height: 260px;
  top: 0;
  left: 0;
  transform: rotate(-3deg);
  z-index: 1;
}

/* Middle photo: right side, partially behind front */
.events__photo--mid {
  width: 320px;
  height: 290px;
  top: 60px;
  right: 0;
  transform: rotate(2deg);
  z-index: 2;
}

/* Front photo: largest, bottom center, slight left tilt */
.events__photo--front {
  width: 300px;
  height: 340px;
  bottom: 0;
  left: 40px;
  transform: rotate(1deg);
  z-index: 3;
  background: var(--light);
}
</style>
