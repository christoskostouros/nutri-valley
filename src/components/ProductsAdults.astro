---
/* ProductsAdults.astro — ΠΡΟΪΟΝΤΑ ΓΙΑ ΕΝΗΛΙΚΕΣ
   Oval/pill product cards carousel
   4 visible items: PREMIUM ΚΟΝΣΕΡΒΕΣ, ΜΠΑΡΕΣ ΠΡΩΤΕΪΝΗΣ, ΓΚΟΦΡΕΤΕΣ, ΤΑΧΙΝΙ
*/

// Images are 725×1200px RGBA PNGs from Anima export
// Each is a pill-shaped card with background+product baked in (alpha outside oval)
const products = [
  { id: 1, name: 'PREMIUM\nΚΟΝΣΕΡΒΕΣ',  href: '/proionta/konserves', image: '/assets/images/product-card-01.webp' },
  { id: 2, name: 'ΜΠΑΡΕΣ\nΠΡΩΤΕΪΝΗΣ',  href: '/proionta/mpares',    image: '/assets/images/product-card-02.webp' },
  { id: 3, name: 'ΓΚΟΦΡΕΤΕΣ',            href: '/proionta/gkofretes', image: '/assets/images/product-card-03.webp' },
  { id: 4, name: 'ΤΑΧΙΝΙ',               href: '/proionta/taxini',    image: '/assets/images/product-card-04.webp' },
  { id: 5, name: 'ΝΙΦΑΔΕΣ\nΒΡΩΜΗΣ',     href: '/proionta/nifades',   image: '/assets/images/product-card-05.webp' },
];
---

<section class="section products-adults" aria-labelledby="adults-title">
  <div class="container">

    <div class="products-adults__header">
      <h2 id="adults-title" class="heading-section">ΠΡΟΪΟΝΤΑ ΓΙΑ ΕΝHΛΙΚΕΣ</h2>
      <p class="section-subtitle">Ανακαλύψτε τη γεύση που συναντά τη διατροφική αξία. Προϊόντα φτιαγμένα για τον σύγχρονο τρόπο ζωής, με ποιοτικά υλικά και μοναδική απόλαυση σε κάθε μπουκιά.</p>
    </div>

    <div class="products-adults__carousel-wrap">
      <!-- Prev arrow -->
      <button class="slider-arrow products-adults__arrow products-adults__arrow--prev" aria-label="Προηγούμενο">
        <svg viewBox="0 0 20 20" fill="none"><path d="M13 4L7 10L13 16" stroke="#474444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

      <div class="products-adults__track" id="adults-track">
        {products.map((p) => (
          <a href={p.href} class="product-oval">
            <!-- The Anima PNG is the complete oval card: product photo + bg + oval shape (alpha outside) -->
            <img src={p.image} alt={p.name.replace('\n', ' ')} class="product-oval__img" loading="lazy" />
            <span class="product-oval__name">
              {p.name.split('\n').map((line, i) => (
                <span key={i}>{line}<br /></span>
              ))}
            </span>
          </a>
        ))}
      </div>

      <!-- Next arrow -->
      <button class="slider-arrow products-adults__arrow products-adults__arrow--next" aria-label="Επόμενο">
        <svg viewBox="0 0 20 20" fill="none"><path d="M7 4L13 10L7 16" stroke="#474444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    <div style="display:flex; justify-content:center; margin-top:50px;">
      <a href="/proionta" class="btn btn-dark">ΟΛΑ ΤΑ ΠΡΟΙΟΝΤΑ</a>
    </div>
  </div>
</section>

<style>
.products-adults {
  background: #F7F5F2;
}

.products-adults__header {
  text-align: center;
  margin-bottom: 60px;
}

.section-subtitle {
  font-size: 17px;
  font-weight: 400;
  line-height: 1.6;
  color: var(--dark);
  opacity: 0.75;
  max-width: 700px;
  margin: 20px auto 0;
}

.products-adults__carousel-wrap {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16px;
}

.products-adults__track {
  display: flex;
  gap: 28px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  flex: 1;
  padding: 20px 4px 30px;
}
.products-adults__track::-webkit-scrollbar { display: none; }

.products-adults__arrow {
  flex-shrink: 0;
  z-index: 2;
}

/* Oval product card — image IS the oval pill (RGBA PNG with alpha outside) */
.product-oval {
  flex: 0 0 280px;
  /* height matches 725:1200 aspect = 280 * 1200/725 ≈ 463px */
  scroll-snap-align: start;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  transition: transform 0.3s ease;
  cursor: pointer;
  text-decoration: none;
}
.product-oval:hover {
  transform: translateY(-8px);
}

/* The Anima image already has the oval/pill shape in its alpha channel */
.product-oval__img {
  width: 280px;
  height: auto;
  display: block;
  /* preserve the transparent alpha around the oval */
}

.product-oval__name {
  margin-top: 16px;
  text-align: center;
  font-size: 15px;
  font-weight: 700;
  letter-spacing: 1.5px;
  color: var(--dark);
  text-transform: uppercase;
  line-height: 1.4;
}
</style>
