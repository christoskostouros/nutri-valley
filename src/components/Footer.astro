---
/* Footer.astro — XD specs compliant
   Floating white card with rounded corners (30px border-radius)
   Left column: Logo + copyright with 259px gap
   Right column: Contact info + legal links (top row) + powered by + social (bottom row)
*/
---

<footer class="footer">
  <div class="footer-card">
    <!-- Left column: Logo + Copyright -->
    <div class="footer-left">
      <a href="/" class="footer-logo" aria-label="Nutri Valley - Αρχική">
        <img src="/assets/images/nutri-valley-logo.svg" alt="Nutri Valley" width="217" height="45" />
      </a>
      <p class="footer-copyright">© Nutri Valley 2025. All Rights Reserved</p>
    </div>

    <!-- Right column: Contact + Legal + Powered + Social -->
    <div class="footer-right">
      <!-- Top row: Contact info + Icons + Legal links -->
      <div class="footer-top-row">
        <!-- Icons column -->
        <div class="footer-icons">
          <svg width="22" height="22" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="icon">
            <path d="M3 5C3 4.44772 3.44772 4 4 4H7.27924C7.47329 4 7.6488 4.12015 7.72412 4.30039L9.22412 7.80039C9.30988 8.01394 9.25935 8.25462 9.10557 8.40825L7.60557 9.90825C8.48613 11.6729 9.82711 13.0139 11.5918 13.8944L13.0918 12.3944C13.2454 12.2407 13.4861 12.1901 13.6996 12.2759L17.1996 13.7759C17.3799 13.8512 17.5 14.0267 17.5 14.2208V17.5C17.5 18.0523 17.0523 18.5 16.5 18.5H16C8.82029 18.5 3 12.6797 3 5.5V5Z" stroke="#474444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <svg width="22" height="22" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="icon">
            <path d="M2.5 6.5L10 11L17.5 6.5M3 5H17C17.5523 5 18 5.44772 18 6V14C18 14.5523 17.5523 15 17 15H3C2.44772 15 2 14.5523 2 14V6C2 5.44772 2.44772 5 3 5Z" stroke="#474444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <svg width="22" height="22" viewBox="0 0 20 20" fill="none" aria-hidden="true" class="icon">
            <path d="M10 2C7.23858 2 5 4.23858 5 7C5 10.75 10 18 10 18C10 18 15 10.75 15 7C15 4.23858 12.7614 2 10 2Z" stroke="#474444" stroke-width="1.5"/>
            <circle cx="10" cy="7" r="2" stroke="#474444" stroke-width="1.5"/>
          </svg>
        </div>

        <!-- Contact info column -->
        <div class="footer-contact-info">
          <a href="tel:+302120001022">+30 212 000 1022</a>
          <a href="mailto:info@nutrivalley.gr">info@nutrivalley.gr</a>
          <address>Ικαρίας 16, Κηφισιά</address>
        </div>

        <!-- Legal links column -->
        <nav class="footer-legal" aria-label="Legal links">
          <a href="/oroi-xrhshs">Όροι Χρήσης</a>
          <a href="/politikh-aporrihtou">Πολιτική Απορρήτου</a>
          <a href="/politikh-cookies">Πολιτική Cookies</a>
        </nav>
      </div>

      <!-- Bottom row: Powered by + Social links -->
      <div class="footer-bottom-row">
        <span class="footer-powered">
          Powered by <a href="https://thinktank.gr" target="_blank" rel="noopener">Thinktank</a>
        </span>
        <nav class="footer-social" aria-label="Social media links">
          <a href="https://facebook.com/nutrivalley" target="_blank" rel="noopener">Facebook</a>
          <a href="https://instagram.com/nutrivalley" target="_blank" rel="noopener">Instagram</a>
          <a href="https://facebook.com/nutrivalleykids" target="_blank" rel="noopener" class="social-kids">Facebook Kids</a>
          <a href="https://instagram.com/nutrivalleykids" target="_blank" rel="noopener" class="social-kids">Instagram Kids</a>
        </nav>
      </div>
    </div>
  </div>
</footer>

<style>
/* ===== FOOTER CARD ===== */
.footer {
  background: transparent;
  padding: 50px 0;
  display: flex;
  justify-content: center;
}

.footer-card {
  background-color: white;
  border-radius: 30px;
  display: flex;
  flex-direction: row;
  gap: 167px;
  height: 400px;
  min-width: 1820px;
  padding: 27.5px 30px;
}

/* LEFT COLUMN: Logo + Copyright */
.footer-left {
  width: 276px;
  display: flex;
  flex-direction: column;
  gap: 259px;
}

.footer-logo {
  display: flex;
  align-self: flex-start;
}

.footer-logo img {
  width: 217px;
  height: 45px;
}

.footer-copyright {
  font-size: 15px;
  font-weight: 400;
  letter-spacing: 0.07px;
  line-height: 40px;
  color: #474444;
  margin: 0;
  align-self: flex-end;
}

/* RIGHT COLUMN: Contact + Legal + Powered + Social */
.footer-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 171px;
}

/* Top row: Icons + Contact + Legal */
.footer-top-row {
  display: flex;
  flex-direction: row;
  gap: 28px;
  height: 135px;
  min-width: 586px;
  align-items: flex-start;
}

.footer-icons {
  width: 22px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  align-self: flex-end;
  min-height: 118px;
  justify-content: space-between;
}

.footer-icons .icon {
  width: 22px;
  height: 22px;
}

.footer-contact-info {
  display: flex;
  flex-direction: column;
  gap: 18px;
  font-size: 17px;
  font-weight: 500;
  letter-spacing: 0.09px;
  line-height: 40px;
  color: #474444;
}

.footer-contact-info a,
.footer-contact-info address {
  font-size: 17px;
  font-weight: 500;
  letter-spacing: 0.09px;
  line-height: 40px;
  color: #474444;
  text-decoration: none;
  font-style: normal;
  margin: 0;
  transition: color 0.2s;
}

.footer-contact-info a:hover {
  color: var(--green, #7a8c5b);
}

.footer-legal {
  display: flex;
  flex-direction: column;
  gap: 18px;
  margin: 0;
  padding: 0;
}

.footer-legal a {
  font-size: 17px;
  font-weight: 500;
  letter-spacing: 0.09px;
  line-height: 40px;
  color: #474444;
  text-decoration: none;
  transition: color 0.2s;
}

.footer-legal a:hover {
  color: var(--green, #7a8c5b);
}

/* Bottom row: Powered by + Social */
.footer-bottom-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24px;
}

.footer-powered {
  font-size: 14px;
  font-weight: 400;
  color: #474444;
}

.footer-powered a {
  color: #474444;
  text-decoration: none;
  transition: color 0.2s;
}

.footer-powered a:hover {
  color: var(--green, #7a8c5b);
}

.footer-social {
  display: flex;
  flex-direction: row;
  gap: 24px;
  margin: 0;
  padding: 0;
}

.footer-social a {
  font-size: 14px;
  font-weight: 400;
  color: #474444;
  text-decoration: none;
  transition: color 0.2s;
}

.footer-social a:hover {
  color: var(--green, #7a8c5b);
}

.footer-social a.social-kids {
  color: #7a8c5b;
  font-weight: 500;
}

.footer-social a.social-kids:hover {
  opacity: 0.75;
}
</style>
